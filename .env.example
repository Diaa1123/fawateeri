# ═══ Airtable ═══
# من: https://airtable.com/account → API section
AIRTABLE_API_KEY=your_airtable_api_key_here
# من: افتح الـ Base → Help → API Documentation → الـ URL فيه الـ ID
AIRTABLE_BASE_ID=your_base_id_here
AIRTABLE_INVOICES_TABLE=your_invoices_table_id
AIRTABLE_USERS_TABLE=your_users_table_id

# ═══ JWT ═══
# سر عشوائي لتشفير التوكنات — أي نص طويل عشوائي
JWT_SECRET=your_random_jwt_secret_here

# ═══ Google Drive ═══
# من: https://console.cloud.google.com → APIs & Services → Credentials
# أنشئ Service Account → حمّل JSON key → انسخ محتوى الملف كامل كـ JSON string
GOOGLE_DRIVE_CREDENTIALS={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id

# ═══ OpenAI ═══
# من: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# ═══ Make.com Webhook ═══
# مفتاح سري للتحقق من الطلبات القادمة من Make.com
MAKE_WEBHOOK_SECRET=your_webhook_secret_here

# ═══ App ═══
NEXT_PUBLIC_APP_URL=http://localhost:3000
